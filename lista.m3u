## LITESPEED WP CACHE PLUGIN - Do not edit the contents of this block! ##
# END NON_LSCACHE

# BEGIN LSCACHE
## LITESPEED WP CACHE PLUGIN - Do not edit the contents of this block! ##
<IfModule mod_rewrite.c>
RewriteEngine on
RewriteRule litespeed/debug/.*\.log$ - [F,L]
RewriteRule \.litespeed_conf\.dat - [F,L]
</IfModule>
<IfModule LiteSpeed>
CacheLookup on
RewriteRule .* - [E=Cache-Control:no-autoflush]

### marker ASYNC start ###
RewriteCond %{REQUEST_URI} /wp-admin/admin-ajax\.php
RewriteCond %{QUERY_STRING} action=async_litespeed
RewriteRule .* - [E=noabort:1]
### marker ASYNC end ###

### marker MOBILE start ###
RewriteCond %{HTTP_USER_AGENT} Mobile|Android|Silk/|Kindle|BlackBerry|Opera\ Mini|Opera\ Mobi|iPhone|iPad|iPod|webOS|IEMobile|Tablet [NC]
RewriteRule .* - [E=Cache-Control:vary=%{ENV:LSCACHE_VARY_VALUE}+ismobile]
### marker MOBILE end ###

### marker NOCACHE COOKIES start ###
RewriteCond %{HTTP_COOKIE} wpconsent|wpconsent_preferences|wpconsent\-
RewriteRule .* - [E=Cache-Control:no-cache]
### marker NOCACHE COOKIES end ###

### marker NOCACHE USER AGENTS start ###
RewriteCond %{HTTP_USER_AGENT} Googlebot|bingbot|YandexBot|DuckDuckBot|Baiduspider|facebookexternalhit|Twitterbot|LinkedInBot|WhatsApp|Slackbot|google\-inspectiontool|AhrefsBot|SemrushBot|MJ12bot [NC]
RewriteRule .* - [E=Cache-Control:no-cache]
### marker NOCACHE USER AGENTS end ###

### marker LOGIN COOKIE start ###
RewriteRule .? - [E="Cache-Vary:wordpress_logged_in_,wp-postpass_,comment_author_,wordpress_test_cookie,wp_woocommerce_session_,wordpressuser_,wordpresspass_,wordpress_sec_,,wp-postpass_0dbcbbc5fc2a87fc03517f0dfcfdcddc"]
### marker LOGIN COOKIE end ###

</IfModule>
## LITESPEED WP CACHE PLUGIN - Do not edit the contents of this block! ##
# END LSCACHE

# ============================================
# LITESPEED CACHE - EXCLUSÕES DINÂMICAS
# ============================================
<IfModule LiteSpeed>
RewriteEngine On

RewriteCond %{REQUEST_URI} yt-player-pro [NC,OR]
RewriteCond %{REQUEST_URI} hls-player-pro [NC,OR]
RewriteCond %{REQUEST_URI} \.m3u8$ [NC,OR]
RewriteCond %{REQUEST_URI} \.ts$ [NC,OR]
RewriteCond %{REQUEST_URI} hls\.min\.js [NC]
RewriteRule .* - [E=Cache-Control:no-cache]

RewriteCond %{REQUEST_URI} tvvote-pro [NC,OR]
RewriteCond %{QUERY_STRING} vote_id= [NC]
RewriteRule .* - [E=Cache-Control:no-cache]

RewriteCond %{REQUEST_URI} glostv-search [NC,OR]
RewriteCond %{QUERY_STRING} search= [NC,OR]
RewriteCond %{QUERY_STRING} ^s= [NC]
RewriteRule .* - [E=Cache-Control:no-cache]

RewriteCond %{REQUEST_URI} bug-report-button [NC,OR]
RewriteCond %{QUERY_STRING} bug_report= [NC]
RewriteRule .* - [E=Cache-Control:no-cache]

RewriteCond %{REQUEST_URI} independent-analytics [NC]
RewriteRule .* - [E=Cache-Control:no-cache]

RewriteCond %{REQUEST_URI} cookieadmin [NC,OR]
RewriteCond %{REQUEST_URI} consent\.js [NC]
RewriteRule .* - [E=Cache-Control:no-cache]

RewriteCond %{REQUEST_URI} ^/wp-json/tvbr-epg/ [NC,OR]
RewriteCond %{REQUEST_URI} ^/wp-json/busca/ [NC,OR]
RewriteCond %{REQUEST_URI} ^/wp-json/glostv/ [NC,OR]
RewriteCond %{REQUEST_URI} ^/wp-json/iawp/ [NC]
RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>

# ============================================
# SERVIR ROBOTS E VERIFICAÇÕES
# ============================================
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^robots\.txt$ - [L]
RewriteRule ^BingSiteAuth\.xml$ - [L]
</IfModule>

# ============================================
# REDIRECT BLACKHOLE
# ============================================
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{QUERY_STRING} blackhole= [NC]
RewriteRule ^$ https://glostv.com/? [R=301,L]
</IfModule>

# ============================================
# FORÇAR HTTPS
# ============================================
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ============================================
# PROTEÇÃO DE SEGURANÇA
# ============================================
<IfModule mod_rewrite.c>
RewriteEngine On

# Bloquear subdomínios internos
RewriteCond %{HTTP_HOST} ^(webdisk|cpcalendars|cpcontacts|mail)\.glostv\.com$ [NC]
RewriteRule .* - [F,L]

RewriteCond %{HTTP_REFERER} mail\.glostv\.com [NC]
RewriteRule .* - [F,L]

# Bloquear user agents vazios
RewriteCond %{HTTP_USER_AGENT} ^-?$ [NC]
RewriteRule .* - [F,L]

# Bloqueio de Feeds RSS
RewriteCond %{REQUEST_URI} /(feed|rss|atom)/?$ [NC]
RewriteRule ^(.*)(feed|rss|atom)/?$ /$1 [R=301,L]

# Blindagem Anti-Backdoor PHP
RewriteRule ^wp-includes/.*\.php$ - [F,L]
RewriteRule ^wp-content/uploads/.*\.php$ - [F,L]
RewriteRule ^wp-content/(?!plugins/|themes/).*\.php$ - [F,L]
RewriteRule ^(wp-fast|about|class|radio|marijuana|404|alfa|shell|eval|up|upload|filemanager|license|theme|config|update|install|wp-wp|wp-signup2|mar|teste|test|priv|private|tmp|temp|cache|data|backup|old|new|admin-ajax2|admin2|login2|site|blog)\.php$ - [F,L]
RewriteRule \.(php3|php4|php5|php7|phtml|phps|suspected|phar|exe|sh|cgi|dll)$ - [F,L]

</IfModule>

# ============================================
# BLOQUEIO ANTI-BOT — ACRESCIMO 2026
# ============================================
<IfModule mod_rewrite.c>
RewriteEngine On

# Bloquear curl, Wget e scripts (exceto seu servidor)
RewriteCond %{HTTP_USER_AGENT} (curl|libwww-perl|python|scrapy|aiohttp|axios|fetch) [NC]
RewriteCond %{REMOTE_ADDR} !^127\.0\.0\.1$
RewriteCond %{REMOTE_ADDR} !^2a02:4780:14:ccb5::1$
RewriteRule .* - [F,L]

# Proteger endpoints JSON de acesso sem referer interno
RewriteCond %{REQUEST_URI} ^/wp-json/ [NC]
RewriteCond %{HTTP_REFERER} !glostv\.com [NC]
RewriteCond %{HTTP_REFERER} !^$
RewriteRule .* - [F,L]
</IfModule>

# ============================================
# REDIRECIONAMENTO 301 URLs ANTIGAS
# ============================================
<IfModule mod_rewrite.c>
RewriteEngine On

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/tv-ao-vivo/ [NC]
RewriteCond %{REQUEST_URI} !^/nossasenhoraaparecida012 [NC]
RewriteCond %{REQUEST_URI} !^/wp-admin [NC]
RewriteCond %{REQUEST_URI} !^/wp-login [NC]
RewriteCond %{REQUEST_URI} !^/wp-content [NC]
RewriteCond %{REQUEST_URI} !^/wp-includes [NC]
RewriteCond %{REQUEST_URI} !^/wp-json [NC]
RewriteCond %{REQUEST_URI} !^/wp-cron [NC]
RewriteCond %{REQUEST_URI} !^/sitemap [NC]
RewriteCond %{REQUEST_URI} !^/feed [NC]
RewriteCond %{REQUEST_URI} !^/robots.txt [NC]
RewriteCond %{REQUEST_URI} !^/favicon.ico [NC]
RewriteCond %{REQUEST_URI} !^/service-worker.js [NC]
RewriteCond %{REQUEST_URI} !\.xml(\.gz)?$ [NC]
RewriteCond %{REQUEST_URI} !\.xsl$ [NC]

RewriteCond %{REQUEST_URI} !^/$ [NC]
RewriteCond %{REQUEST_URI} !^/(14175-2|tv-por-categorias|tv-ao-vivo-brasil|tv-ao-vivo-brasil-2|populares|populares-top|estados|estados-2|categorias|politica-de-privacidade|politica-de-privacidade-2|politica-de-cookies|politica-de-cookies-2|termos-de-uso|termos-de-uso-3|sobre-nos|sobre-nos-3|contato|glostv-assistir-tv-online-ao-vivo-gratis|guia-de-jogos-tv-hoje-ao-vivo|guia-jogos-da-tv-hoje)/?$ [NC]

RewriteCond %{REQUEST_URI} !^/category/ [NC]
RewriteCond %{REQUEST_URI} !^/tag/ [NC]
RewriteCond %{REQUEST_URI} !^/author/ [NC]

RewriteRule ^([^/]+)/?$ /tv-ao-vivo/$1/ [R=301,L]
</IfModule>

# BEGIN WordPress
# As diretrizes (linhas) entre "BEGIN WordPress" e "END WordPress" são
# geradas dinamicamente e só devem ser modificadas através de filtros do WordPress.
# Quaisquer alterações nas diretivas entre esses marcadores serão sobrescritas.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>

# END WordPress

