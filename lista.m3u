tant;font-weight:300!important;line-height:1!important;display:inline-block!important}.pic-close-inner{position:absolute!important;top:8px!important;right:8px!important;width:32px!important;height:32px!important;min-width:32px!important;min-height:32px!important;color:#64748b!important;font-size:22px!important;border-radius:50%!important;background:#f1f5f9!important;z-index:10!important}.pic-close-inner:hover,.pic-close-inner:focus{background:#e2e8f0!important;color:#1e293b!important;outline:0!important}.pic-close-inner:active{background:#cbd5e1!important}.pic-close-inner .pic-close-x{font-size:22px!important;font-weight:400!important;line-height:1!important;display:inline-block!important;margin-top:-2px!important}.pic-modal{position:fixed!important;top:50%!important;left:50%!important;transform:translate(-50%,-50%) scale(.92)!important;background:#fff!important;border-radius:14px!important;box-shadow:0 25px 60px rgba(0,0,0,.35)!important;width:calc(100% - 40px)!important;max-width:500px!important;max-height:85vh!important;overflow:hidden!important;display:flex!important;flex-direction:column!important;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif!important;box-sizing:border-box!important;transition:transform .25s ease!important;z-index:2147483647!important;margin:0!important;padding:0!important}.pic-visible .pic-modal{transform:translate(-50%,-50%) scale(1)!important}.pic-hiding .pic-modal{transform:translate(-50%,-50%) scale(.92)!important}.pic-ad-label{display:block!important;padding:12px 18px 6px!important;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif!important;font-size:11px!important;font-weight:500!important;color:#94a3b8!important;text-transform:uppercase!important;letter-spacing:.6px!important;line-height:1!important;box-sizing:border-box!important;margin:0!important;background:#fff!important;text-align:left!important}.pic-ad-container{display:block!important;padding:8px 18px 18px!important;width:100%!